<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Task Management Report</title>
    <style>
        body {
            font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: #334155;
            line-height: 1.5;
            margin: 0;
            padding: 40px;
            background-color: #fff;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #0f172a;
            margin: 0 0 10px 0;
            font-size: 28px;
            font-weight: 700;
        }

        .meta-info {
            display: flex;
            justify-content: space-between;
            color: #64748b;
            font-size: 14px;
            margin-top: 10px;
        }

        .section-title {
            color: #1e293b;
            font-size: 20px;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 8px;
            margin-top: 30px;
            margin-bottom: 15px;
            font-weight: 600;
        }

        /* Summary Cards */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .summary-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
        }

        .summary-card.highlight {
            background: #eff6ff;
            border-color: #bfdbfe;
            color: #1d4ed8;
        }

        .summary-card .value {
            font-size: 24px;
            font-weight: bold;
            color: #0f172a;
            margin: 5px 0 0 0;
        }

        .summary-card .label {
            font-size: 13px;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
            font-size: 13px;
            page-break-inside: auto;
        }

        th,
        td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }

        th {
            background-color: #f8fafc;
            color: #475569;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 0.5px;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        tr:nth-child(even) {
            background-color: #fbfbfc;
        }

        /* Status Badges */
        .status {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
            display: inline-block;
        }

        .status-Completed {
            background: #dcfce7;
            color: #166534;
        }

        .status-In-Progress {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-On-Hold {
            background: #fef3c7;
            color: #92400e;
        }

        .status-Not-Started {
            background: #f1f5f9;
            color: #475569;
        }

        .delayed-badge {
            background: #fee2e2;
            color: #b91c1c;
            margin-top: 4px;
        }

        /* Footer */
        .footer {
            margin-top: 50px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
            padding-top: 20px;
        }
    </style>
</head>

<body>

    <div class="header">
        <h1>Task Management Monthly Report</h1>
        <div class="meta-info">
            <span><strong>Date Range:</strong>
                <%= dateRangeTitle %>
            </span>
            <span><strong>Generated On:</strong>
                <%= generatedOn %>
            </span>
            <span><strong>Generated By:</strong>
                <%= generatedBy %>
            </span>
        </div>
    </div>

    <!-- Section 1: Summary Overview -->
    <h2 class="section-title">Summary Overview</h2>
    <div class="summary-grid">
        <div class="summary-card highlight">
            <div class="label">Total Tasks</div>
            <div class="value">
                <%= totalTasks %>
            </div>
        </div>
        <div class="summary-card">
            <div class="label">Completed</div>
            <div class="value">
                <%= completedTasks %>
            </div>
        </div>
        <div class="summary-card">
            <div class="label">Completion %</div>
            <div class="value">
                <%= completionPercentage %>%
            </div>
        </div>
        <div class="summary-card">
            <div class="label">In Progress</div>
            <div class="value">
                <%= inProgress %>
            </div>
        </div>
        <div class="summary-card">
            <div class="label">On Hold</div>
            <div class="value">
                <%= onHold %>
            </div>
        </div>
        <div class="summary-card">
            <div class="label" style="color:#b91c1c;">Delayed</div>
            <div class="value" style="color:#b91c1c;">
                <%= delayedTasks %>
            </div>
        </div>
    </div>

    <!-- Section 2: Track-wise Breakdown -->
    <h2 class="section-title">Track-wise Breakdown</h2>
    <table>
        <thead>
            <tr>
                <th>Track</th>
                <th>Total Tasks</th>
                <th>Completed</th>
                <th>Delayed</th>
            </tr>
        </thead>
        <tbody>
            <% trackBreakdown.forEach(function(track) { %>
                <tr>
                    <td><strong>
                            <%= track.track %>
                        </strong></td>
                    <td>
                        <%= track.total %>
                    </td>
                    <td>
                        <%= track.completed %>
                    </td>
                    <td>
                        <% if (track.delayed> 0) { %>
                            <span style="color:#b91c1c;font-weight:bold;">
                                <%= track.delayed %>
                            </span>
                            <% } else { %>
                                <span>
                                    <%= track.delayed %>
                                </span>
                                <% } %>
                    </td>
                </tr>
                <% }); %>
                    <% if (trackBreakdown.length===0) { %>
                        <tr>
                            <td colspan="4" style="text-align: center;">No data available</td>
                        </tr>
                        <% } %>
        </tbody>
    </table>

    <!-- Section 3: Assignee Performance -->
    <h2 class="section-title">Top Contributors (Completed Tasks)</h2>
    <table>
        <thead>
            <tr>
                <th>Assignee</th>
                <th>Completed Tasks</th>
            </tr>
        </thead>
        <tbody>
            <% topContributors.forEach(function(contributor) { %>
                <tr>
                    <td>
                        <%= contributor.name %>
                    </td>
                    <td>
                        <%= contributor.completedCount %>
                    </td>
                </tr>
                <% }); %>
                    <% if (topContributors.length===0) { %>
                        <tr>
                            <td colspan="2" style="text-align: center;">No contributors yet</td>
                        </tr>
                        <% } %>
        </tbody>
    </table>

    <!-- Section 4: Detailed Task List -->
    <h2 class="section-title">Detailed Task List</h2>
    <table>
        <thead>
            <tr>
                <th width="5%">S.No.</th>
                <th width="20%">Task Title</th>
                <th width="10%">Track</th>
                <th width="12%">Assigned To</th>
                <th width="10%">Dates</th>
                <th width="13%">Status</th>
                <th width="30%">Comments</th>
            </tr>
        </thead>
        <tbody>
            <% tasks.forEach(function(task, index) { %>
                <tr>
                    <td>
                        <%= index + 1 %>
                    </td>
                    <td><strong>
                            <%= task.title %>
                        </strong></td>
                    <td>
                        <%= task.track %>
                    </td>
                    <td>
                        <%= task.assignee ? task.assignee.name : 'Unassigned' %>
                    </td>
                    <td style="font-size: 11px; line-height: 1.4; white-space: nowrap;">
                        <span style="color: #64748b;">Start:</span>
                        <%= new Date(task.startDate).toLocaleDateString() %><br />
                            <span style="color: #64748b;">Due:</span>
                            <%= new Date(task.tentativeEndDate).toLocaleDateString() %>
                                <% if (task.status==='Completed' && task.actualEndDate) { %>
                                    <br /><span style="color: #64748b;">Done:</span>
                                    <%= new Date(task.actualEndDate).toLocaleDateString() %>
                                        <% } %>
                    </td>
                    <td>
                        <div class="status status-<%= task.status.replace(' ', '-') %>">
                            <%= task.status %>
                        </div>
                        <% if (task.status !=='Completed' && new Date(task.tentativeEndDate) < new Date()) { %>
                            <div class="status delayed-badge">Delayed</div>
                            <% } %>
                    </td>
                    <td style="font-size: 11px; color: #64748b;">
                        <%= task.comments || '-' %>
                    </td>
                </tr>
                <% }); %>
                    <% if (tasks.length===0) { %>
                        <tr>
                            <td colspan="7" style="text-align: center;">No tasks found for this period</td>
                        </tr>
                        <% } %>
        </tbody>
    </table>

    <div class="footer">
        Generated from Internal Task Tracker System &copy; <%= new Date().getFullYear() %>
    </div>

</body>

</html>